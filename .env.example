# Токен бота от @BotFather (ОБЯЗАТЕЛЬНО получи новый — старый нужно отозвать!)
BOT_TOKEN=

# Пароль для входа в админ-панель (команда /admin). Придумай новый, не используй старый "169169"
ADMIN_PASSWORD=

# Юзернеймы админов через запятую, без @ и без пробелов вокруг запятой
ADMIN_USERNAMES=aquaee,underworldcrush,naseqvm

# API-ключ NOWPayments — для приёма оплаты Premium в крипте
# Получить: https://account.nowpayments.io/create-account
NOWPAYMENTS_API_KEY=

# Сколько бесплатных алертов и монет в портфеле доступно без Premium
FREE_ALERT_LIMIT=1
FREE_PORTFOLIO_LIMIT=1

# Цена Premium в долларах и на сколько дней активируется за один платёж
PREMIUM_PRICE_USD=4
PREMIUM_DAYS=30

# Путь к файлу базы данных. Локально можно не трогать.
# На Railway — обязательно поменяй на /data/bot.db после подключения Volume (см. README)
DB_PATH=bot.db

# Сколько бесплатных расчётов в калькуляторе доступно без Premium (админам всегда безлимит)
FREE_CALC_LIMIT=5

# Сколько бонусных попыток калькулятора получают оба — и пригласивший, и приглашённый
REFERRAL_BONUS=5

# Публичный URL мини-приложения. Оставь пустым при первом деплое —
# заполнишь после того, как Railway выдаст домен (см. README, раздел Mini App)
MINI_APP_URL=

# Юзернейм (без @), которому в Mini App при открытии покажется картинка-сюрприз.
# Оставь пустым, если фича не нужна.
SURPRISE_USERNAME=naseqvm

# В какой час по UTC отправлять ежедневную сводку портфеля всем, у кого есть монеты в портфеле
# (9 UTC = 12:00 по Киеву летом). Отправляется не чаще раза в день на юзера.
DAILY_SUMMARY_HOUR_UTC=9
