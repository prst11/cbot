# Токен бота от @BotFather (ОБЯЗАТЕЛЬНО получи новый — старый нужно отозвать!)
BOT_TOKEN=

# Пароль для входа в админ-панель (команда /admin). Придумай новый, не используй старый "169169"
ADMIN_PASSWORD=

# Юзернеймы админов через запятую, без @ и без пробелов вокруг запятой
ADMIN_USERNAMES=aquaee,underworldcrush

# API-ключ NOWPayments — для приёма оплаты Premium в крипте
# Получить: https://account.nowpayments.io/create-account
NOWPAYMENTS_API_KEY=

# Сколько бесплатных алертов и монет в портфеле доступно без Premium
FREE_ALERT_LIMIT=1
FREE_PORTFOLIO_LIMIT=1

# Цена Premium в долларах и на сколько дней активируется за один платёж
PREMIUM_PRICE_USD=4
PREMIUM_DAYS=30

# Путь к файлу базы данных. Локально можно не трогать.
# На Railway — обязательно поменяй на /data/bot.db после подключения Volume (см. README)
DB_PATH=bot.db
